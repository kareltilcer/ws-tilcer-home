# Frontend build-time config (Vite). Copy to .env.production (or set in Coolify).

# Base URL of the shared auth service (SPA login + /token/refresh live here).
# Required for the production build's Mode A auth.
VITE_AUTH_BASE_URL=https://auth.tilcer.cz

# Force real Mode A auth in dev (default: off in dev, on in production builds).
# Leave unset for offline dev with the dev-admin stub.
# VITE_REAL_AUTH=true
